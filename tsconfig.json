{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,

    "types": ["node"],

    "lib": ["ES2022"],

    "skipLibCheck": true
  },

  "include": ["**/*.ts"],

  "exclude": ["node_modules", "dist"]
}